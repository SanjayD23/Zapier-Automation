# ─────────────────────────────────────────────────────────────
# BharatFlow — Environment Variables
# ─────────────────────────────────────────────────────────────
# DO NOT commit this file to version control.

# ── WhatsApp Cloud API (Meta Business Suite) ──────────────────
WHATSAPP_ACCESS_TOKEN=YOUR_META_SYSTEM_USER_ACCESS_TOKEN_HERE
WHATSAPP_PHONE_NUMBER_ID=YOUR_PHONE_NUMBER_ID_HERE
WHATSAPP_API_VERSION=v19.0

# ── Gmail OAuth2 ──────────────────────────────────────────────
GMAIL_CLIENT_ID=YOUR_GOOGLE_OAUTH_CLIENT_ID_HERE
GMAIL_CLIENT_SECRET=YOUR_GOOGLE_OAUTH_CLIENT_SECRET_HERE
GMAIL_REFRESH_TOKEN=YOUR_GMAIL_REFRESH_TOKEN_HERE

# ── AI / Summarizer (e.g. OpenAI or Gemini) ──────────────────
OPENAI_API_KEY=YOUR_OPENAI_KEY_HERE
GEMINI_API_KEY=YOUR_GEMINI_KEY_HERE

# ── App Config ────────────────────────────────────────────────
APP_SECRET_KEY=changeme-generate-a-random-64char-secret
DATABASE_PATH=BharatFlow.db
DEBUG=true
